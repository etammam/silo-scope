#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 1. Get staged files, handle empty results safely
# The 'tr' command helps handle potential newline issues across OSs
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=d | grep '\.cs$' | tr '\n' ' ')

if [ -z "$STAGED_CS_FILES" ]; then
  echo "No C# files staged, skipping CSharpier."
  exit 0
fi

echo "Running CSharpier formatting..."

# 2. Run format using the variable directly.
# Using the variable instead of xargs is often more stable across different 'sh' versions.
dotnet csharpier format $STAGED_CS_FILES

# 3. Re-add only the files we formatted
for file in $STAGED_CS_FILES; do
  git add "$file"
done

echo "Done!"
